        </mxCell>
        <mxCell id="safe_result" value="&lt;b&gt;小规模风险被修复&lt;/b&gt;&lt;br&gt;Core-7：21/21 可行&lt;br&gt;3/3 获胜；中位收益 +5.414" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="1280" y="350" width="220" height="95" as="geometry" />
        </mxCell>
        <mxCell id="rejected" value="排除该候选&lt;br&gt;不读取 Core-7" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#F8CECC;strokeColor=#B85450;fontSize=13;" vertex="1" parent="1">
