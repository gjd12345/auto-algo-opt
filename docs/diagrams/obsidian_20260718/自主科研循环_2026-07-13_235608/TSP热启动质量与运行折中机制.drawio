        </mxCell>
        <mxCell id="extension_test" value="&lt;b&gt;冻结后扩展验证&lt;/b&gt;&lt;br&gt;5 个 TSPLIB 实例&lt;br&gt;n=442–3038；不重新选候选" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1280" y="520" width="220" height="85" as="geometry" />
        </mxCell>
        <mxCell id="extension_fail" value="&lt;b&gt;大规模外推失败&lt;/b&gt;&lt;br&gt;inherited：0/15 可行&lt;br&gt;fresh：11/15 可行" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#F8CECC;strokeColor=#B85450;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="1280" y="650" width="220" height="95" as="geometry" />
        </mxCell>
        <mxCell id="boundary" value="&lt;b&gt;修正后的证据边界&lt;/b&gt;&lt;br&gt;运行探针只守住目标规模 n=280&lt;br&gt;不能写成 TSPLIB-full 鲁棒；需把大规模门槛加入确认协议" style="shape=note;whiteSpace=wrap;html=1;align=left;verticalAlign=middle;spacingLeft=10;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=13;" vertex="1" parent="1">
