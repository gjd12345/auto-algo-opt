        <mxCell id="validation" value="&lt;b&gt;冻结验证&lt;/b&gt;&lt;br&gt;a280 跨 seed：12/12 安全分类正确&lt;br&gt;合成 n=442：8 安全、4 超时，12/12 正确&lt;br&gt;两轮均为 0 false-safe" style="shape=note;whiteSpace=wrap;html=1;align=left;verticalAlign=middle;spacingLeft=10;fillColor=#F5F5F5;strokeColor=#666666;fontSize=13;" vertex="1" parent="1">
