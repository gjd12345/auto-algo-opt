        <mxCell id="pool" value="&lt;b&gt;历史 top-6&lt;/b&gt;&lt;br&gt;605-run 精英作为起点&lt;br&gt;不重新随机初始化" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="40" y="130" width="180" height="90" as="geometry" />
        </mxCell>
        <mxCell id="evolution" value="&lt;b&gt;四代短预算进化&lt;/b&gt;&lt;br&gt;只按训练 objective 排名" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="280" y="130" width="180" height="90" as="geometry" />
        </mxCell>
        <mxCell id="slow_region" value="&lt;b&gt;最终种群慢区&lt;/b&gt;&lt;br&gt;seed 8101 前五名&lt;br&gt;a280 全部超过 30 秒" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#F8CECC;strokeColor=#B85450;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="520" y="130" width="190" height="90" as="geometry" />
        </mxCell>
        <mxCell id="objective_choice" value="&lt;b&gt;objective 第一名&lt;/b&gt;&lt;br&gt;质量较高&lt;br&gt;但 Core-7 为 20/21 可行" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#F8CECC;strokeColor=#B85450;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="770" y="130" width="190" height="90" as="geometry" />
        </mxCell>
        <mxCell id="population" value="&lt;b&gt;保留最终 top-6&lt;/b&gt;&lt;br&gt;第六名是历史种子&lt;br&gt;训练只比第一名差 1.19%" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="280" y="350" width="190" height="95" as="geometry" />
        </mxCell>
        <mxCell id="probe" value="&lt;b&gt;合成 dev 运行探针&lt;/b&gt;&lt;br&gt;n=120 / 160 / 200&lt;br&gt;外推 n=280 运行时间" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="530" y="350" width="190" height="95" as="geometry" />
        </mxCell>
        <mxCell id="decision" value="预测运行时间&lt;br&gt;&lt;b&gt;&amp;lt; 30 秒？&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="790" y="345" width="150" height="105" as="geometry" />
        </mxCell>
        <mxCell id="safe_choice" value="&lt;b&gt;安全候选中选 objective 最优&lt;/b&gt;&lt;br&gt;8101 改选第六名&lt;br&gt;8102/8103 保留第一名" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=14;" vertex="1" parent="1">
