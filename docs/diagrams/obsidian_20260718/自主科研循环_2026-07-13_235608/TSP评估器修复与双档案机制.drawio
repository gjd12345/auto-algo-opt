        <mxCell id="title" value="&lt;b&gt;TSP 大规模失败的拆解：评估器偏差、候选成本与双档案选择&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=22;fontColor=#1F2937;" vertex="1" parent="1">
          <mxGeometry x="240" y="20" width="1120" height="45" as="geometry" />
        </mxCell>
        <mxCell id="old_result" value="&lt;b&gt;旧 Core-12 观察&lt;/b&gt;&lt;br&gt;进化终态扩展集 0/15&lt;br&gt;pcb3038 各臂普遍超时" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#F8CECC;strokeColor=#B85450;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="40" y="120" width="210" height="95" as="geometry" />
        </mxCell>
        <mxCell id="floor_test" value="&lt;b&gt;极简基线检查&lt;/b&gt;&lt;br&gt;first-unvisited / nearest-neighbor&lt;br&gt;pr1002 约 2.8 秒；pcb3038 都超时" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="310" y="120" width="235" height="95" as="geometry" />
        </mxCell>
        <mxCell id="evaluator_cause" value="&lt;b&gt;评估器共同成本&lt;/b&gt;&lt;br&gt;每步线性扫描 route&lt;br&gt;每步复制完整 n×n 距离矩阵&lt;br&gt;候选还没运行完，评估器先耗尽 30 秒" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#F8CECC;strokeColor=#B85450;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="605" y="110" width="245" height="115" as="geometry" />
        </mxCell>
        <mxCell id="shadow" value="&lt;b&gt;影子评估器&lt;/b&gt;&lt;br&gt;布尔 visited + 共享只读距离矩阵&lt;br&gt;Core-7：14/14 结果精确一致" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="910" y="120" width="235" height="95" as="geometry" />
        </mxCell>
        <mxCell id="fix" value="&lt;b&gt;正式修复并推送&lt;/b&gt;&lt;br&gt;commit 9e3c63f&lt;br&gt;429 passed，1 skipped" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1210" y="120" width="210" height="95" as="geometry" />
        </mxCell>
        <mxCell id="fixed_eval" value="&lt;b&gt;修复后冻结 Core-12 重算&lt;/b&gt;&lt;br&gt;7 个唯一代码 × 12 实例&lt;br&gt;选择不读取 Core-12" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="85" y="355" width="225" height="100" as="geometry" />
        </mxCell>
        <mxCell id="fresh" value="&lt;b&gt;fresh 终态&lt;/b&gt;&lt;br&gt;34/36 可行&lt;br&gt;仅 seed 8101 在 pr1002 / pcb3038 超时" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="385" y="335" width="215" height="100" as="geometry" />
        </mxCell>
        <mxCell id="evolved" value="&lt;b&gt;继承后进化终态&lt;/b&gt;&lt;br&gt;21/36 可行&lt;br&gt;大规模仍被候选内部多层模拟拖慢" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#F8CECC;strokeColor=#B85450;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="680" y="335" width="225" height="100" as="geometry" />
        </mxCell>
        <mxCell id="archive" value="&lt;b&gt;只读可扩展档案 rank4&lt;/b&gt;&lt;br&gt;36/36 可行；对 fresh 29/0/7&lt;br&gt;12 实例方向 10 正、2 负&lt;br&gt;中位 gap 收益 +3.49" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="985" y="325" width="245" height="120" as="geometry" />
        </mxCell>
        <mxCell id="same_quality" value="&lt;b&gt;同质量实现对照&lt;/b&gt;&lt;br&gt;rank3 循环与 rank4 向量化&lt;br&gt;Core-12 gap 完全一致&lt;br&gt;pcb3038：rank4 快 4.6×" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1290" y="325" width="225" height="120" as="geometry" />
        </mxCell>
        <mxCell id="retention" value="&lt;b&gt;机制判断&lt;/b&gt;&lt;br&gt;历史池并不缺少可扩展解&lt;br&gt;objective-only 进化与最终保留把它挤出终态" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="400" y="590" width="275" height="105" as="geometry" />
        </mxCell>
        <mxCell id="dual_archive" value="&lt;b&gt;双档案选择&lt;/b&gt;&lt;br&gt;质量档案：保留训练最优&lt;br&gt;可扩展档案：保留通过大规模门槛的轻量同质解&lt;br&gt;两者都从同一冻结池读取" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="760" y="575" width="300" height="125" as="geometry" />
        </mxCell>
        <mxCell id="concurrency" value="&lt;b&gt;测量规则修正&lt;/b&gt;&lt;br&gt;4 并发失败中 3 个被串行复核恢复&lt;br&gt;临界运行时间必须单路复核&lt;br&gt;不能把资源争用写成算法失败" style="shape=note;whiteSpace=wrap;html=1;align=left;verticalAlign=middle;spacingLeft=10;fillColor=#F5F5F5;strokeColor=#666666;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="80" y="585" width="260" height="115" as="geometry" />
        </mxCell>
        <mxCell id="next" value="&lt;b&gt;下一轮确认&lt;/b&gt;&lt;br&gt;同一 20-run 轨迹同时报告：&lt;br&gt;objective 第一名 / 可扩展档案&lt;br&gt;Core-12 可行率优先于 gap" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=14;" vertex="1" parent="1">
